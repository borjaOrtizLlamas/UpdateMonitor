# Copy this file to .env and fill in your values.
# The .env file is read by docker-compose; never commit it.
# Env vars always take priority over config.json values.

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
# Protects all write/delete/config endpoints. Use a strong random value.
SERVER_ADMIN_KEY=change-me

# Optional: path to a JSON config file for values you prefer not to set as env vars.
# CONFIG_FILE=/etc/updatemonitor/config.json

# ── AWS S3 ────────────────────────────────────────────────────────────────────
S3_BUCKET=my-updatemonitor-bucket
S3_REGION=us-east-1
# Prefix inside the bucket (default: updatemonitor/)
# S3_PREFIX=updatemonitor/

# AWS credentials — only needed when not running with an IAM role / instance profile.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# For local development with LocalStack or MinIO:
# S3_ENDPOINT=http://localhost:4566

# ── Source trackers ───────────────────────────────────────────────────────────
# GitHub: optional token — raises rate limit from 60 → 5 000 req/hr.
# GITHUB_TOKEN=ghp_...

# GitLab: optional token for public repos on gitlab.com.
# For a self-hosted instance, also set GITLAB_BASE_URL.
# GITLAB_TOKEN=glpat-...
# GITLAB_BASE_URL=https://gitlab.example.com

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Standard cron expression. Default: every 30 minutes.
# CHECK_INTERVAL=*/30 * * * *

# ── AI ────────────────────────────────────────────────────────────────────────
AI_API_KEY=sk-ant-...
# Model to use for update analysis. Default: claude-sonnet-4-6
# AI_MODEL=claude-sonnet-4-6

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notify@example.com
# SMTP_PASSWORD=...
# SMTP_FROM=updatemonitor@example.com

# ── Container timezone ────────────────────────────────────────────────────────
# Set so cron intervals align with your local time rather than UTC.
# TZ=Europe/Madrid
